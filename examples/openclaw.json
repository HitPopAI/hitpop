{
  "agents": {
    "defaults": {
      "model": "zai/glm-5-turbo",
      "maxConcurrent": 4,
      "subagents": {
        "maxConcurrent": 8,
        "maxSpawnDepth": 2,
        "maxChildrenPerAgent": 8,
        "runTimeoutSeconds": 900
      }
    },
    "list": [
      {
        "id": "main",
        "default": true,
        "name": "🎬 Hitpop",
        "workspace": "~/.openclaw/workspace-hitpop",
        "agentDir": "~/.openclaw/agents/main/agent",
        "subagents": {
          "allowAgents": ["planner", "creative", "critic", "producer", "writer", "reviewer", "scout", "promoter"]
        }
      },
      {
        "id": "planner",
        "name": "🧠 Planner",
        "model": "zai/glm-5-turbo",
        "workspace": "~/.openclaw/workspace-hitpop/.agents/planner",
        "agentDir": "~/.openclaw/agents/planner/agent"
      },
      {
        "id": "creative",
        "name": "💡 Creative",
        "model": "zai/glm-5-turbo",
        "workspace": "~/.openclaw/workspace-hitpop/.agents/creative",
        "agentDir": "~/.openclaw/agents/creative/agent"
      },
      {
        "id": "critic",
        "name": "🎯 Critic",
        "model": "zai/glm-5-turbo",
        "workspace": "~/.openclaw/workspace-hitpop/.agents/critic",
        "agentDir": "~/.openclaw/agents/critic/agent"
      },
      {
        "id": "producer",
        "name": "💻 Producer",
        "model": "zai/glm-5-turbo",
        "workspace": "~/.openclaw/workspace-hitpop/.agents/producer",
        "agentDir": "~/.openclaw/agents/producer/agent"
      },
      {
        "id": "writer",
        "name": "✍️ Writer",
        "model": "zai/glm-5-turbo",
        "workspace": "~/.openclaw/workspace-hitpop/.agents/writer",
        "agentDir": "~/.openclaw/agents/writer/agent"
      },
      {
        "id": "reviewer",
        "name": "🔍 Reviewer",
        "model": "zai/glm-5-turbo",
        "workspace": "~/.openclaw/workspace-hitpop/.agents/reviewer",
        "agentDir": "~/.openclaw/agents/reviewer/agent"
      },
      {
        "id": "scout",
        "name": "📰 Scout",
        "model": "zai/glm-4.7-flash",
        "workspace": "~/.openclaw/workspace-hitpop/.agents/scout",
        "agentDir": "~/.openclaw/agents/scout/agent"
      },
      {
        "id": "promoter",
        "name": "📣 Promoter",
        "model": "zai/glm-5-turbo",
        "workspace": "~/.openclaw/workspace-hitpop/.agents/promoter",
        "agentDir": "~/.openclaw/agents/promoter/agent"
      }
    ]
  },
  "tools": {
    "profile": "full",
    "agentToAgent": {
      "enabled": true,
      "allow": ["main", "planner", "creative", "critic", "producer", "writer", "reviewer", "scout", "promoter"]
    },
    "sessions": {
      "visibility": "all"
    }
  }
}
